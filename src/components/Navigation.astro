---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
    <div class="flex items-center justify-between py-2">
      <a href="/" class="relative z-50">
        <img src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1773983715/IMG_6436_huwok5.png" alt="E.V Design Studio" class="h-16 lg:h-20 w-auto" />
      </a>

      <nav class="hidden lg:flex items-center gap-10">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "relative text-[13px] font-medium uppercase tracking-[0.15em] transition-colors duration-300",
              currentPath === href || (href !== "/" && currentPath.startsWith(href))
                ? "text-white"
                : "text-stone-200 hover:text-white",
            ]}
          >
            {label}
            {(currentPath === href || (href !== "/" && currentPath.startsWith(href))) && (
              <span class="absolute -bottom-1 left-0 w-full h-px bg-accent" />
            )}
          </a>
        ))}
      </nav>

      <a
        href="/contact"
        class="hidden lg:inline-flex items-center gap-2 border border-stone-500 px-5 py-2.5 text-[11px] font-medium uppercase tracking-[0.2em] text-stone-200 transition-all duration-300 hover:border-white hover:text-white hover:bg-white/5"
      >
        Get in Touch
      </a>

      <button
        id="mobile-menu-btn"
        class="relative z-50 flex flex-col gap-1.5 lg:hidden p-2"
        aria-label="Toggle menu"
      >
        <span class="menu-line block h-px w-6 bg-white transition-all duration-300 origin-center"></span>
        <span class="menu-line block h-px w-6 bg-white transition-all duration-300"></span>
        <span class="menu-line block h-px w-4 bg-white transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 bg-stone-950/98 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500"
  >
    <nav class="flex flex-col items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="font-[Playfair_Display] text-3xl font-light text-stone-300 hover:text-white transition-colors duration-300"
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-4 border border-stone-700 px-8 py-3 text-[11px] font-medium uppercase tracking-[0.2em] text-stone-300 hover:border-white hover:text-white transition-all duration-300"
      >
        Free Consultation
      </a>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById("main-nav")!;
  const menuBtn = document.getElementById("mobile-menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const lines = menuBtn.querySelectorAll(".menu-line");
  let menuOpen = false;

  window.addEventListener("scroll", () => {
    if (window.scrollY > 80) {
      nav.classList.add("bg-stone-950/90", "backdrop-blur-md", "py-0");
      nav.classList.remove("py-2");
    } else {
      nav.classList.remove("bg-stone-950/90", "backdrop-blur-md", "py-0");
      nav.classList.add("py-2");
    }
  });

  menuBtn.addEventListener("click", () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");
      lines[0].classList.add("rotate-45", "translate-y-[4px]");
      lines[1].classList.add("opacity-0");
      lines[2].classList.add("-rotate-45", "-translate-y-[3px]", "w-6");
      document.body.style.overflow = "hidden";
    } else {
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      lines[0].classList.remove("rotate-45", "translate-y-[4px]");
      lines[1].classList.remove("opacity-0");
      lines[2].classList.remove("-rotate-45", "-translate-y-[3px]", "w-6");
      document.body.style.overflow = "";
    }
  });
</script>
