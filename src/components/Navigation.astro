---
import { SITE, NAV_LINKS } from "../data/site";

const currentPath = Astro.url.pathname;
---

<div class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 py-2.5 flex items-center justify-center">
    <p class="text-xs sm:text-sm tracking-[0.15em] uppercase font-medium text-center">
      Authentic Armenian Pastries & Breads — Baked Fresh Daily
    </p>
  </div>
</div>

<header class="sticky top-0 z-50 bg-white border-b border-stone-100">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <button
        id="mobile-menu-btn"
        type="button"
        class="lg:hidden p-2 -ml-2 text-stone-700 hover:text-primary transition-colors"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>

      <nav class="hidden lg:flex items-center gap-8">
        {NAV_LINKS.slice(0, 3).map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "text-sm tracking-[0.08em] uppercase font-medium transition-colors duration-200 hover:text-primary",
              currentPath === href ? "text-primary" : "text-stone-700",
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <a href="/" class="text-center flex-shrink-0 mx-4 lg:mx-12">
        <span class="font-serif text-2xl lg:text-3xl text-stone-900 leading-tight block">Sam's</span>
        <span class="text-[0.55rem] lg:text-[0.6rem] tracking-[0.3em] uppercase text-stone-500 font-medium block -mt-0.5">Armenian Bakery</span>
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        {NAV_LINKS.slice(3).map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "text-sm tracking-[0.08em] uppercase font-medium transition-colors duration-200 hover:text-primary",
              currentPath === href ? "text-primary" : "text-stone-700",
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <a
        href="/contact"
        class="lg:hidden p-2 -mr-2 text-stone-700 hover:text-primary transition-colors"
        aria-label="Contact"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </a>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-[calc(theme(spacing.16)+37px)] bg-white z-40 transform translate-x-[-100%] transition-transform duration-300 ease-out-expo"
    aria-hidden="true"
  >
    <nav class="px-6 py-8">
      <ul class="space-y-1">
        {NAV_LINKS.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "block py-3 text-lg tracking-[0.05em] uppercase font-medium border-b border-stone-100 transition-colors",
                currentPath === href ? "text-primary" : "text-stone-700 hover:text-primary",
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-8 pt-6 border-t border-stone-200">
        <a href="tel:+18182476281" class="flex items-center gap-3 text-stone-600 hover:text-primary transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <span class="text-sm">(818) 247-6281</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  if (btn && menu) {
    btn.addEventListener("click", () => {
      const isOpen = menu.getAttribute("aria-hidden") === "false";
      menu.setAttribute("aria-hidden", isOpen ? "true" : "false");
      menu.style.transform = isOpen ? "translateX(-100%)" : "translateX(0)";
      btn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      document.body.style.overflow = isOpen ? "" : "hidden";
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.setAttribute("aria-hidden", "true");
        menu.style.transform = "translateX(-100%)";
        btn.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      });
    });
  }
</script>
