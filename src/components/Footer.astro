---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-stone-800/50 bg-stone-950">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-12 pt-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 pb-16 border-b border-stone-800/50">
      <div class="lg:col-span-1">
        <a href="/" class="inline-block">
          <span class="font-[Playfair_Display] text-3xl font-semibold tracking-wide text-white">
            E.V
          </span>
          <span class="block text-[10px] font-light uppercase tracking-[0.35em] text-stone-500 mt-1">
            Design Studio
          </span>
        </a>
        <p class="mt-6 text-sm leading-relaxed text-stone-500 max-w-xs">
          A trusted partner for clients who expect excellence in architecture, planning, and design.
        </p>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-400 mb-6">Navigation</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-stone-500 hover:text-white transition-colors duration-300">Home</a></li>
          <li><a href="/portfolio" class="text-sm text-stone-500 hover:text-white transition-colors duration-300">Portfolio</a></li>
          <li><a href="/about" class="text-sm text-stone-500 hover:text-white transition-colors duration-300">About</a></li>
          <li><a href="/contact" class="text-sm text-stone-500 hover:text-white transition-colors duration-300">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-400 mb-6">Services</h4>
        <ul class="space-y-3">
          <li><span class="text-sm text-stone-500">Architecture</span></li>
          <li><span class="text-sm text-stone-500">Plans</span></li>
          <li><span class="text-sm text-stone-500">Permitting</span></li>
          <li><span class="text-sm text-stone-500">Consulting</span></li>
          <li><span class="text-sm text-stone-500">Tutorials</span></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-400 mb-6">Contact</h4>
        <ul class="space-y-3">
          <li>
            <a href="mailto:info@evdesignstudio.com" class="text-sm text-stone-500 hover:text-white transition-colors duration-300">
              info@evdesignstudio.com
            </a>
          </li>
          <li>
            <a href="tel:+1234567890" class="text-sm text-stone-500 hover:text-white transition-colors duration-300">
              +1 (234) 567-890
            </a>
          </li>
          <li class="text-sm text-stone-500">Los Angeles, California</li>
        </ul>
        <div class="flex gap-4 mt-6">
          <a href="#" class="text-stone-600 hover:text-white transition-colors duration-300" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="text-stone-600 hover:text-white transition-colors duration-300" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8">
      <p class="text-xs text-stone-600">
        &copy; {currentYear} E.V Design Studio. All Rights Reserved.
      </p>
      <p class="text-xs text-stone-600">
        Architecture &middot; Plans &middot; Permitting &middot; Consulting &middot; Tutorials
      </p>
    </div>
  </div>
</footer>
