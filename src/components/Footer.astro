---
import { SITE, NAV_LINKS, CONTACT_INFO, SOCIAL_LINKS, SERVICES, SERVICES_TAGLINE } from "../data/site";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-stone-800/50 bg-stone-950">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-12 pt-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 pb-16 border-b border-stone-800/50">
      <div class="lg:col-span-1">
        <a href="/" class="inline-block">
          <img src={SITE.logoUrl} alt={SITE.name} class="h-40 lg:h-44 w-auto" />
        </a>
        <p class="mt-2 text-[10px] lg:text-[11px] font-medium uppercase tracking-[0.2em] text-accent">
          {SITE.tagline}
        </p>
        <p class="mt-6 text-sm leading-relaxed text-stone-500 max-w-xs">
          A trusted partner for clients who expect excellence in architecture, planning, and design.
        </p>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-400 mb-6">Navigation</h4>
        <ul class="space-y-3">
          {NAV_LINKS.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-stone-500 hover:text-white transition-colors duration-300">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-400 mb-6">Services</h4>
        <ul class="space-y-3">
          {SERVICES.map((service) => (
            <li><span class="text-sm text-stone-500">{service}</span></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-400 mb-6">Contact</h4>
        <ul class="space-y-3">
          <li>
            <a href={`mailto:${CONTACT_INFO.email}`} class="text-sm text-stone-500 hover:text-white transition-colors duration-300">
              {CONTACT_INFO.email}
            </a>
          </li>
          <li>
            <a href={CONTACT_INFO.phoneHref} class="text-sm text-stone-500 hover:text-white transition-colors duration-300">
              {CONTACT_INFO.phone}
            </a>
          </li>
          <li class="text-sm text-stone-500">{CONTACT_INFO.location}</li>
        </ul>
        <div class="flex gap-4 mt-6">
          {SOCIAL_LINKS.map((social) => (
            <a href={social.href} class="text-stone-600 hover:text-white transition-colors duration-300" aria-label={social.label}>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8">
      <p class="text-xs text-stone-600">
        &copy; {currentYear} {SITE.name}. All Rights Reserved.
      </p>
      <p class="text-xs text-stone-600" set:html={SERVICES_TAGLINE} />
    </div>
  </div>
</footer>
