---
import {
  buildPortfolioListingSections,
  PORTFOLIO_TAB_ORDER,
  formatCategoryLabel,
  type PortfolioItem,
  type PortfolioListingSection,
} from "../data/portfolio";

interface Props {
  items: PortfolioItem[];
  /** Omit or `undefined` for full lists (portfolio page). Set a number (e.g. 6) to cap items per tab on the home preview. */
  maxItems?: number;
  /** Unique id suffix for filter controls and grid, e.g. `page` or `home`. */
  listingId: string;
  /** Vertical padding around the filter tab row (default `py-12` — equal space above and below). */
  tabsMarginClass?: string;
}

const { items, maxItems, listingId, tabsMarginClass = "py-12" } = Astro.props;
const { variant, sections } = buildPortfolioListingSections(items, maxItems);

function dataGroup(sec: PortfolioListingSection): string {
  return sec.variant === "unlimited" ? sec.group : sec.filterKey;
}

function projectsOf(sec: PortfolioListingSection): PortfolioItem[] {
  return sec.projects;
}
---

<div class="portfolio-listing-root" data-portfolio-listing-variant={variant}>
  <div
    class:list={["flex flex-wrap gap-1 animate-fade-up", tabsMarginClass]}
    style="animation-delay: 0.4s"
    id={`portfolio-tabs-${listingId}`}
  >
    <button
      type="button"
      data-filter="all"
      class="filter-btn active px-4 py-3 md:px-6 text-[10px] md:text-[11px] font-semibold uppercase tracking-[0.15em] md:tracking-[0.2em] text-white bg-stone-800 transition-all duration-300"
    >
      All
    </button>
    {PORTFOLIO_TAB_ORDER.map(({ group, label }) => (
      <button
        type="button"
        data-filter={group}
        class="filter-btn px-4 py-3 md:px-6 text-[10px] md:text-[11px] font-semibold uppercase tracking-[0.15em] md:tracking-[0.2em] text-stone-500 hover:text-white transition-all duration-300"
      >
        {label}
      </button>
    ))}
  </div>
</div>

<div id={`portfolio-grid-${listingId}`}>
  {sections.map((sec) => {
    const projects = projectsOf(sec);
    if (projects.length === 0) return null;
    const groupAttr = dataGroup(sec);
    return (
      <div
        class="portfolio-category mb-20 lg:mb-28 last:mb-0"
        data-portfolio-group={groupAttr}
      >
        <div class="flex flex-col gap-16 lg:gap-24">
          {projects.map((project, i) => (
            <article
              class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 lg:items-center reveal-on-scroll"
              style={`transition-delay: ${Math.min(i * 0.08, 0.4)}s`}
            >
              <a
                href={`/portfolio/${project.slug}`}
                class="group relative block aspect-[4/3] overflow-hidden lg:max-h-[min(100vw,28rem)]"
              >
                <img
                  src={project.thumbnail}
                  alt={project.title}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                  loading="lazy"
                />
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-stone-950/50 via-transparent to-transparent opacity-60 transition-opacity duration-500 group-hover:opacity-80" />
              </a>

              <div class="flex flex-col justify-center min-w-0">
                <p class="text-[10px] font-medium uppercase tracking-[0.25em] text-stone-400 mb-3">
                  {formatCategoryLabel(project.category)} &middot; {project.status}
                </p>
                <h3 class="font-[Playfair_Display] text-2xl md:text-3xl lg:text-[2rem] font-normal text-white leading-snug">
                  {project.title}
                </h3>
                <p class="text-sm text-stone-400 mt-2">
                  {project.location} &middot; {project.year}
                </p>
                <p class="mt-5 text-sm md:text-base leading-relaxed text-stone-500 line-clamp-4">
                  {project.description}
                </p>
                <a
                  href={`/portfolio/${project.slug}`}
                  class="mt-8 inline-flex items-center gap-2 text-[11px] font-medium uppercase tracking-[0.15em] text-stone-400 hover:text-white transition-colors duration-300 w-fit"
                >
                  View Project
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    );
  })}
</div>

<script is:inline define:vars={{ listingId, variant }}>
  (function () {
    const id = listingId;
    const listingVariant = variant;
    const tabsRoot = document.getElementById("portfolio-tabs-" + id);
    const gridRoot = document.getElementById("portfolio-grid-" + id);
    if (!tabsRoot || !gridRoot) return;

    const buttons = tabsRoot.querySelectorAll(".filter-btn");
    const categories = gridRoot.querySelectorAll(".portfolio-category");

    function setFilter(filter) {
      buttons.forEach(function (btn) {
        const isActive = btn.dataset.filter === filter;
        btn.classList.toggle("active", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("bg-stone-800", isActive);
        btn.classList.toggle("text-stone-500", !isActive);
      });

      categories.forEach(function (el) {
        const group = el.dataset.portfolioGroup;
        var show;
        if (listingVariant === "limited") {
          show = filter === "all" ? group === "all" : group === filter;
        } else {
          show = filter === "all" || group === filter;
        }
        el.classList.toggle("hidden", !show);
      });
    }

    buttons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var f = btn.dataset.filter || "all";
        setFilter(f);
      });
    });

    setFilter("all");
  })();
</script>
