---
import Layout from "../layouts/Layout.astro";
import { HOME_LOVE_ITEMS } from "../data/home-loves";
---

<Layout title="Home">

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden bg-cream">
    <div class="relative max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 items-center">
        <div class="order-2 lg:order-1 px-6 py-16 lg:py-24 lg:px-12 xl:px-20 text-center lg:text-left">
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl text-stone-900 leading-[1.1] mb-6">
            <span class="italic">Baked with</span><br />tradition.
          </h1>
          <p class="text-stone-600 text-base lg:text-lg leading-relaxed max-w-lg mx-auto lg:mx-0 mb-8">
            Authentic Armenian pastries and savory hot foods — from gata and lahmajun to daily favorites —
            made fresh in Glendale with family recipes and quality ingredients.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a
              href="/menu"
              class="inline-flex items-center justify-center px-8 py-3.5 bg-primary text-white text-sm tracking-[0.12em] uppercase font-medium hover:bg-primary-dark transition-colors duration-200"
            >
              View Our Menu
            </a>
            <a
              href="/about"
              class="inline-flex items-center justify-center px-8 py-3.5 border border-stone-300 text-stone-700 text-sm tracking-[0.12em] uppercase font-medium hover:border-primary hover:text-primary transition-colors duration-200"
            >
              Our Story
            </a>
          </div>
        </div>
        <div class="order-1 lg:order-2 relative">
          <div class="relative aspect-[4/3] lg:aspect-auto lg:h-[600px] xl:h-[650px] overflow-hidden">
            <img
              src="/media/uploads/home-hero.jpg"
              alt="Powdered pastries at the counter — inside Sam's bakery"
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            <div
              class="pointer-events-none absolute inset-0 bg-black/10"
              aria-hidden="true"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MARQUEE BANNER ═══ -->
  <div class="bg-primary overflow-hidden py-3.5" aria-label="Scrolling highlights">
    <div class="marquee-track flex whitespace-nowrap">
      {[...Array(4)].map(() => (
        <div class="flex items-center shrink-0">
          <span class="flex items-center gap-2 mx-8 text-white text-xs sm:text-sm tracking-[0.15em] uppercase font-medium">
            <svg class="w-4 h-4 opacity-60" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Made in Glendale
          </span>
          <span class="flex items-center gap-2 mx-8 text-white text-xs sm:text-sm tracking-[0.15em] uppercase font-medium">
            <svg class="w-4 h-4 opacity-60" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Baked Fresh Daily
          </span>
          <span class="flex items-center gap-2 mx-8 text-white text-xs sm:text-sm tracking-[0.15em] uppercase font-medium">
            <svg class="w-4 h-4 opacity-60" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Traditional Recipes
          </span>
          <span class="flex items-center gap-2 mx-8 text-white text-xs sm:text-sm tracking-[0.15em] uppercase font-medium">
            <svg class="w-4 h-4 opacity-60" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Family Owned
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══ FEATURED SPECIALTIES ═══ -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-end justify-between mb-10 lg:mb-14">
        <h2 class="font-serif text-3xl lg:text-4xl text-stone-900">What Our Customers LOVE!</h2>
        <a href="/menu" class="hidden sm:inline-flex items-center gap-2 text-sm tracking-[0.08em] uppercase font-medium text-primary hover:text-primary-dark transition-colors">
          Full Menu
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {HOME_LOVE_ITEMS.map((item) => (
          <button
            type="button"
            class="group block w-full cursor-pointer text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-sm"
            data-menu-photo
            data-src={item.image}
            data-title={item.title}
            data-price={item.price}
            data-description={item.description ?? ""}
          >
            <div class="aspect-square mb-4 overflow-hidden bg-gradient-to-br from-amber-50 to-orange-50 rounded-sm">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-serif text-lg text-stone-900 group-hover:text-primary transition-colors">{item.title}</h3>
              <span class="text-sm font-medium text-primary shrink-0 tabular-nums">{item.price}</span>
            </div>
            {item.description ? <p class="text-sm text-stone-500 mt-1">{item.description}</p> : null}
          </button>
        ))}
      </div>

      <div class="mt-8 text-center sm:hidden">
        <a href="/menu" class="inline-flex items-center gap-2 text-sm tracking-[0.08em] uppercase font-medium text-primary">
          View All
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ IMAGE + TEXT — LEFT (Rotated card style) ═══ -->
  <section class="bg-cream py-16 lg:py-28 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 items-center gap-8 lg:gap-16">
        <div class="relative flex items-center justify-center py-8 lg:py-12">
          <div class="angled-shape-left absolute w-[85%] h-[85%] rounded-sm bg-primary/10"></div>
          <div class="relative z-10 w-[80%] max-w-md">
            <img
              src="https://images.unsplash.com/photo-1530610476181-d83430b64dcd?w=700&h=560&fit=crop"
              alt="Baker pulling fresh bread from a stone oven"
              class="angled-photo-left w-full shadow-2xl"
              loading="lazy"
            />
          </div>
        </div>
        <div class="px-2 lg:px-4 xl:px-8">
          <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 mb-5 leading-tight">
            Handcrafted with Heritage
          </h2>
          <p class="text-stone-600 leading-relaxed mb-4">
            Every loaf, pastry, and flatbread at Sam's is made by hand using recipes passed down
            through generations. We use only the finest ingredients — real butter, fresh flour, and
            locally sourced produce — to create baked goods of exceptional quality.
          </p>
          <p class="text-stone-600 leading-relaxed">
            From the warmth of our ovens to the care in every fold, each piece is a tribute to
            the rich baking traditions of Armenia.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ IMAGE + TEXT — RIGHT (Rotated card style) ═══ -->
  <section class="bg-white py-16 lg:py-28 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 items-center gap-8 lg:gap-16">
        <div class="px-2 lg:px-4 xl:px-8 order-2 lg:order-1">
          <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 mb-5 leading-tight">
            Perfect for Every Gathering
          </h2>
          <p class="text-stone-600 leading-relaxed mb-4">
            Whether it is a family celebration, a corporate event, or an intimate gathering,
            our beautifully arranged pastry platters and fresh-baked breads bring warmth and
            elegance to every table.
          </p>
          <p class="text-stone-600 leading-relaxed">
            Each order is prepared with care and presented in our signature packaging,
            ready to impress your guests.
          </p>
        </div>
        <div class="relative flex items-center justify-center py-8 lg:py-12 order-1 lg:order-2">
          <div class="angled-shape-right absolute w-[85%] h-[85%] rounded-sm bg-accent/15"></div>
          <div class="relative z-10 w-[80%] max-w-md">
            <img
              src="https://images.unsplash.com/photo-1608198093002-ad4e005484ec?w=700&h=560&fit=crop"
              alt="Assorted pastries beautifully arranged on a platter"
              class="angled-photo-right w-full shadow-2xl"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOR EVERY OCCASION ═══ -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4">
      <p class="text-xs tracking-[0.2em] uppercase text-primary font-medium text-center mb-3">For Every Occasion</p>
      <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 text-center mb-12 lg:mb-16">How We Can Serve You</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {[
          {
            title: "Catering",
            desc: "From intimate gatherings to grand celebrations, our catering brings the authentic taste of Armenia to your event with beautifully arranged platters.",
            link: "/catering",
            cta: "Learn More",
            img: "https://images.unsplash.com/photo-1556910103-1c02745aae4d?w=600&h=450&fit=crop",
          },
          {
            title: "Custom Orders",
            desc: "Special requests are our specialty. Whether it is a birthday cake, holiday pastries, or a unique creation, we will craft it fresh for you.",
            link: "/contact",
            cta: "Inquire Now",
            img: "https://images.unsplash.com/photo-1517686469429-8bdb88b9f907?w=600&h=450&fit=crop",
          },
          {
            title: "Events",
            desc: "Planning a party, wedding, or corporate function? Let us handle the baked goods so you can focus on making memories.",
            link: "/contact",
            cta: "Get in Touch",
            img: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&h=450&fit=crop",
          },
        ].map((item) => (
          <div class="group bg-white overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={item.img}
                alt={item.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-6 lg:p-8">
              <h3 class="font-serif text-xl text-stone-900 mb-2">{item.title}</h3>
              <p class="text-sm text-stone-500 leading-relaxed mb-5">{item.desc}</p>
              <a
                href={item.link}
                class="inline-flex items-center gap-2 text-sm tracking-[0.08em] uppercase font-medium text-primary hover:text-primary-dark transition-colors"
              >
                {item.cta}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="py-16 lg:py-24 bg-white relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-cream rounded-full opacity-50 blur-3xl pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 relative">
      <div class="text-center mb-12">
        <p class="text-xs tracking-[0.2em] uppercase text-primary font-medium mb-3">What People Say</p>
        <h2 class="font-serif text-3xl lg:text-4xl text-stone-900">Loved by Our Community</h2>
      </div>

      <div class="space-y-10">
        {[
          {
            quote: "The gata at Sam's is unlike anything else in Glendale. It transports me back to my grandmother's kitchen every single time. Absolutely divine.",
            author: "Armine K.",
          },
          {
            quote: "We ordered pastry platters for our daughter's wedding and every guest was raving about them. The presentation was beautiful and the taste was even better.",
            author: "Vartan M.",
          },
          {
            quote: "Their lahmajun is the gold standard. Perfectly thin, wonderfully seasoned, and always fresh. I drive 40 minutes just to get it.",
            author: "Lena S.",
          },
        ].map((item) => (
          <blockquote class="text-center">
            <svg class="w-8 h-8 mx-auto mb-4 text-primary/20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609L9.978 5.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z" />
            </svg>
            <p class="font-display text-xl lg:text-2xl text-stone-800 italic leading-relaxed max-w-2xl mx-auto mb-4">
              "{item.quote}"
            </p>
            <cite class="not-italic text-sm tracking-[0.1em] uppercase text-stone-400 font-medium">{item.author}</cite>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ OUR STORY TEASER ═══ -->
  <section class="bg-stone-900 text-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 items-center">
        <div class="aspect-[4/3] lg:aspect-auto lg:h-[560px] overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1517433367423-c7e5b0f35086?w=800&h=600&fit=crop"
            alt="Inside the bakery — fresh loaves and pastries"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="px-6 py-16 lg:py-0 lg:px-12 xl:px-20">
          <h2 class="font-serif text-3xl lg:text-4xl text-white mb-5 leading-tight">
            The Bakery That Became a Glendale Tradition
          </h2>
          <p class="text-stone-300 leading-relaxed mb-4">
            What began as a small family kitchen has grown into one of Glendale's most beloved
            bakeries. Sam brought the authentic recipes of Armenia to Raleigh Street, and the
            community has kept coming back ever since.
          </p>
          <p class="text-stone-300 leading-relaxed mb-8">
            Every morning, our ovens fill the neighborhood with the scent of fresh bread and
            golden pastries — a tradition we are proud to carry forward.
          </p>
          <a
            href="/about"
            class="inline-flex items-center gap-2 text-sm tracking-[0.12em] uppercase font-medium text-white border-b border-white/40 pb-1 hover:border-white transition-colors"
          >
            Read Our Story
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-25%); }
  }
  .marquee-track {
    animation: marquee 20s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }

  .angled-shape-left {
    transform: rotate(-3deg);
    top: 8%;
    left: 5%;
  }
  .angled-photo-left {
    transform: rotate(-5deg);
  }

  .angled-shape-right {
    transform: rotate(3deg);
    top: 8%;
    right: 5%;
  }
  .angled-photo-right {
    transform: rotate(4deg);
  }

  @media (max-width: 1023px) {
    .angled-shape-left,
    .angled-shape-right {
      width: 90%;
      height: 90%;
    }
  }
</style>
