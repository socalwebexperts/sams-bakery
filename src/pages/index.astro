---
import Layout from "../layouts/Layout.astro";
import { getPortfolioItems } from "../data/portfolio";
import {
  processSteps,
  homeServices,
  homeStats,
  featuredPortfolioSlugs,
  featuredPortfolioLabels,
} from "../data/home";
import { homeAboutHighlights, splitStatNumber } from "../data/stats";

const portfolioItems = await getPortfolioItems();

const portfolioTiles = featuredPortfolioLabels.map((label, i) => {
  const project = portfolioItems.find((p) => p.slug === featuredPortfolioSlugs[i])!;
  return { ...project, label };
});
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative h-[100vh] lg:h-screen flex items-end lg:items-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1920&q=80"
        alt="Architectural masterpiece"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-stone-950 via-stone-950/40 to-stone-950/30"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-stone-950/60 via-transparent to-transparent"></div>
      <div class="absolute inset-0 bg-stone-950/25"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1400px] w-full px-6 lg:px-12 pb-10 lg:pb-12">
      <div class="max-w-3xl">
        <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-stone-300 mb-6 animate-fade-in" style="animation-delay: 0.3s">
          Consulting &middot; Architectural Plans &middot; Engineering Plans &middot; Permitting
        </p>
        <h1 class="font-[Playfair_Display] text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-medium leading-[0.95] text-white animate-fade-up" style="animation-delay: 0.5s">
          Designing<br />
          <span class="italic font-normal text-stone-300">Excellence</span>
        </h1>
        <p class="mt-8 max-w-xl text-base lg:text-lg leading-relaxed text-stone-300 font-light animate-fade-up" style="animation-delay: 0.8s">
          A trusted partner for discerning clients who demand architectural
          vision, engineering precision, and full regulatory confidence.
        </p>
        <div class="mt-10 flex flex-wrap gap-4 animate-fade-up" style="animation-delay: 1s">
          <a
            href="/contact"
            class="inline-flex items-center gap-3 bg-white text-stone-950 px-8 py-4 text-[12px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:bg-stone-200"
          >
            Free Consultation
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a
            href="/portfolio"
            class="inline-flex items-center gap-3 border border-stone-600 text-stone-300 px-8 py-4 text-[12px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:border-white hover:text-white"
          >
            View Work
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-fade-in" style="animation-delay: 1.5s">
      <div class="flex flex-col items-center gap-2 text-stone-500">
        <span class="text-[9px] uppercase tracking-[0.3em]">Scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-stone-500 to-transparent animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-24 lg:py-32 bg-stone-950">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="text-center mb-12 lg:mb-10 max-w-3xl mx-auto reveal-on-scroll">
        <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-accent mb-4">How We Work</p>
        <h2 class="font-[Playfair_Display] text-3xl md:text-4xl lg:text-5xl font-normal text-white">
          Our Process
        </h2>
        <p class="mt-5 text-sm md:text-base leading-relaxed text-stone-400 font-light">
          From initial concept through city review, approvals, construction, and certificate of occupancy — a transparent roadmap so you always know what comes next.
        </p>
      </div>

      <!-- Desktop Process Arrow (lg+) -->
      <div class="hidden lg:block reveal-on-scroll">
        <div class="relative" style="padding-top: 9rem; padding-bottom: 9rem;">
          <div class="flex">
            {processSteps.map((step, i) => (
              <div
                class="relative"
                style={`flex:1;height:72px;${i > 0 ? 'margin-left:-18px;' : ''}z-index:${processSteps.length - i};`}
              >
                <div
                  class="absolute inset-0 flex items-center justify-center"
                  style={`background:${step.color};clip-path:${i === 0 ? 'polygon(0 0,calc(100% - 18px) 0,100% 50%,calc(100% - 18px) 100%,0 100%)' : 'polygon(0 0,calc(100% - 18px) 0,100% 50%,calc(100% - 18px) 100%,0 100%,18px 50%)'};`}
                >
                  <svg class="w-7 h-7 text-white shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={step.icon} />
                </div>

                {step.pos === "top" ? (
                  <div class="absolute bottom-full left-1/2 -translate-x-1/2 flex flex-col items-center w-[min(100%,12rem)]">
                    <p class="text-[11px] font-bold uppercase tracking-[0.1em] text-stone-200 text-center leading-tight mb-1.5">
                      {step.title}
                    </p>
                    <svg class="w-[14px] h-[40px] text-stone-300 shrink-0" viewBox="0 0 14 40" fill="currentColor" aria-hidden="true">
                      <path d="M7 0L14 10H9V40H5V10H0z" />
                    </svg>
                  </div>
                ) : (
                  <div class="absolute top-full left-1/2 -translate-x-1/2 flex flex-col items-center w-[min(100%,12rem)]">
                    <svg class="w-[14px] h-[40px] text-stone-300 shrink-0" viewBox="0 0 14 40" fill="currentColor" aria-hidden="true">
                      <path d="M5 0H9V30H14L7 40L0 30H5z" />
                    </svg>
                    <p class="text-[11px] font-bold uppercase tracking-[0.1em] text-stone-200 text-center leading-tight mt-1.5">
                      {step.title}
                    </p>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Mobile / Tablet Process (below lg) -->
      <div class="lg:hidden reveal-on-scroll">
        <div class="max-w-md mx-auto">
          {processSteps.map((step, i) => (
            <div class="flex items-start gap-4">
              <div class="flex flex-col items-center shrink-0">
                <div class="w-11 h-11 rounded-full flex items-center justify-center" style={`background:${step.color}`}>
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={step.icon} />
                </div>
                {i < processSteps.length - 1 && (
                  <div class="w-0.5 h-8" style={`background:linear-gradient(to bottom,${step.color},${processSteps[i + 1].color})`}></div>
                )}
              </div>
              <div class="pt-2.5 pb-4">
                <p class="text-xs font-semibold uppercase tracking-[0.12em] text-stone-300">{step.title}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- About & Contact -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <div class="reveal-on-scroll">
          <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-accent mb-8">About Our Studio</p>
          <h2 class="font-[Playfair_Display] text-3xl md:text-4xl lg:text-5xl font-normal leading-snug text-white">
            We deliver more than plans — we deliver
            <span class="italic">peace of mind</span>
          </h2>
          <p class="mt-8 text-base lg:text-lg leading-relaxed text-stone-300/70 font-light">
            Our team blends architectural vision with rigorous engineering and permitting
            expertise, ensuring every project is executed with precision, sophistication,
            and full regulatory confidence.
          </p>

          <div class="mt-12 grid grid-cols-2 gap-8">
            {homeAboutHighlights.map(({ number, label }) => {
              const { main, suffix } = splitStatNumber(number);
              return (
                <div>
                  <p class="font-[Playfair_Display] text-3xl lg:text-4xl text-white">
                    {main}
                    {suffix ? <span class="text-accent">{suffix}</span> : null}
                  </p>
                  <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-stone-500 mt-2">{label}</p>
                </div>
              );
            })}
          </div>

          <a
            href="/about"
            class="inline-flex items-center gap-2 mt-12 text-[12px] font-medium uppercase tracking-[0.15em] text-stone-300/60 hover:text-white transition-colors duration-300"
          >
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>

        <div class="reveal-on-scroll" style="transition-delay: 0.15s">
          <div class="border border-white/[0.06] bg-white/[0.02] backdrop-blur-sm p-8 lg:p-10">
            <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-accent mb-3">Free Consultation</p>
            <h3 class="font-[Playfair_Display] text-2xl font-normal text-white mb-1">
              Talk to A Specialist
            </h3>
            <p class="text-sm text-stone-500 mb-8">We'll respond within 24 hours.</p>

            <form id="home-contact-form" class="space-y-5">
              <div>
                <label for="home-name" class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-2.5">
                  Name *
                </label>
                <input
                  type="text"
                  id="home-name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full bg-transparent border-b border-stone-700/80 pb-2.5 text-sm text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                  placeholder="Your full name"
                />
              </div>

              <div class="grid grid-cols-2 gap-5">
                <div>
                  <label for="home-email" class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-2.5">
                    Email *
                  </label>
                  <input
                    type="email"
                    id="home-email"
                    name="email"
                    required
                    autocomplete="email"
                    class="w-full bg-transparent border-b border-stone-700/80 pb-2.5 text-sm text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                    placeholder="john@example.com"
                  />
                </div>
                <div>
                  <label for="home-phone" class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-2.5">
                    Phone
                  </label>
                  <input
                    type="tel"
                    id="home-phone"
                    name="phone"
                    autocomplete="tel"
                    class="w-full bg-transparent border-b border-stone-700/80 pb-2.5 text-sm text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                    placeholder="+1 (234) 567-890"
                  />
                </div>
              </div>

              <div>
                <label for="home-address" class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-2.5">
                  Project Address
                </label>
                <input
                  type="text"
                  id="home-address"
                  name="address"
                  autocomplete="street-address"
                  class="w-full bg-transparent border-b border-stone-700/80 pb-2.5 text-sm text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                  placeholder="123 Main St, Los Angeles, CA"
                />
              </div>

              <div class="grid grid-cols-2 gap-5 items-end">
                <div>
                  <label for="home-projectType" class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-2.5">
                    Project Type
                  </label>
                  <select
                    id="home-projectType"
                    name="projectType"
                    class="w-full bg-transparent border-b border-stone-700/80 pb-2.5 text-sm text-white focus:border-accent focus:outline-none transition-colors duration-300 appearance-none cursor-pointer"
                  >
                    <option value="" class="bg-stone-900">Select type</option>
                    <option value="residential" class="bg-stone-900">Residential</option>
                    <option value="commercial" class="bg-stone-900">Commercial</option>
                  </select>
                </div>
                <div id="home-subcategory-wrap" class="transition-all duration-300 ease-out opacity-0 max-h-0 overflow-hidden pointer-events-none">
                  <label for="home-subcategory" class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-2.5">
                    Scope
                  </label>
                  <select
                    id="home-subcategory"
                    name="subcategory"
                    class="w-full bg-transparent border-b border-stone-700/80 pb-2.5 text-sm text-white focus:border-accent focus:outline-none transition-colors duration-300 appearance-none cursor-pointer"
                  >
                    <option value="" class="bg-stone-900">Select scope</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="home-message" class="block text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-2.5">
                  Tell Us About Your Project *
                </label>
                <textarea
                  id="home-message"
                  name="message"
                  required
                  rows="3"
                  class="w-full bg-transparent border-b border-stone-700/80 pb-2.5 text-sm text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300 resize-none"
                  placeholder="Describe your project, timeline, and any specific requirements..."
                ></textarea>
              </div>

              <div class="flex items-start gap-3 pt-1">
                <input
                  type="checkbox"
                  id="home-constructionEstimate"
                  name="constructionEstimate"
                  value="yes"
                  class="mt-1 h-4 w-4 shrink-0 rounded border-stone-600 bg-stone-950/50 text-accent focus:ring-2 focus:ring-accent/40 focus:ring-offset-0 focus:ring-offset-transparent accent-accent"
                />
                <label for="home-constructionEstimate" class="text-sm text-stone-400 leading-snug cursor-pointer">
                  Get a complete construction estimate?
                </label>
              </div>

              <div id="home-form-error" class="hidden text-red-400 text-sm"></div>

              <div class="pt-2">
                <button
                  type="submit"
                  id="home-submit-btn"
                  class="group inline-flex items-center gap-3 bg-white text-stone-950 px-10 py-3.5 text-[11px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:bg-stone-200 w-full justify-center disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  <span id="home-btn-text">Send Message</span>
                  <svg id="home-btn-arrow" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                  <svg id="home-btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                </button>
              </div>
            </form>

            <div id="home-form-success" class="hidden py-10 text-center">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-full border border-accent/30 mb-5">
                <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" /></svg>
              </div>
              <h3 class="font-[Playfair_Display] text-xl text-white mb-2">Message Sent</h3>
              <p class="text-sm text-stone-400">Thank you for reaching out. We'll be in touch within 24 hours.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="text-center mb-20 reveal-on-scroll">
        <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-accent mb-4">What We Do</p>
        <h2 class="font-[Playfair_Display] text-3xl md:text-4xl lg:text-5xl font-normal text-white">
          Our Services
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-px bg-deep/30">
        {homeServices.map((service, i) => (
          <div
            class="bg-stone-950 p-8 lg:p-10 text-center reveal-on-scroll group hover:bg-stone-900/50 transition-colors duration-500 flex flex-col"
            style={`transition-delay: ${i * 0.1}s`}
          >
            <div class="inline-flex items-center justify-center w-12 h-12 mb-6 mx-auto">
              <svg class="w-8 h-8 text-accent group-hover:text-accent-light transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon} />
            </div>
            <h3 class="text-sm font-semibold uppercase tracking-[0.15em] text-white mb-3 leading-snug min-h-[3.25rem]">
              {service.titleLines[0]}
              {service.titleLines.length > 1 ? <br /> : null}
              {service.titleLines.length > 1 ? service.titleLines[1] : null}
            </h3>
            <p class="text-sm leading-relaxed text-stone-500 min-h-[6rem] flex-1">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="flex items-end justify-between mb-16 reveal-on-scroll">
        <div>
          <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-accent mb-4">Selected Work</p>
          <h2 class="font-[Playfair_Display] text-3xl md:text-4xl lg:text-5xl font-normal text-white">
            Recent Projects
          </h2>
        </div>
        <a
          href="/portfolio"
          class="hidden md:inline-flex items-center gap-2 text-[12px] font-medium uppercase tracking-[0.15em] text-stone-400 hover:text-white transition-colors duration-300"
        >
          View All Projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-2 gap-x-4 gap-y-8 lg:gap-x-6 lg:gap-y-10">
        {portfolioTiles.map((project, i) => (
          <div class="flex flex-col">
            <h3
              class="font-[Playfair_Display] text-lg md:text-xl lg:text-2xl font-normal text-stone-500/65 mb-3 lg:mb-4 tracking-tight reveal-on-scroll"
              style={`transition-delay: ${i * 0.1}s`}
            >
              {project.label}
            </h3>
            <a
              href={`/portfolio/${project.slug}`}
              class="group relative aspect-square overflow-hidden reveal-on-scroll"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <img
                src={project.thumbnail}
                alt={project.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-stone-950/90 via-stone-950/20 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-500"></div>
              <div class="absolute inset-0 flex flex-col justify-end p-6 lg:p-10">
                <div class="transform transition-transform duration-500 group-hover:translate-y-0 translate-y-2">
                  <p class="text-[10px] font-medium uppercase tracking-[0.25em] text-stone-400 mb-2">
                    {project.category} &middot; {project.status}
                  </p>
                  <p class="font-[Playfair_Display] text-xl lg:text-2xl font-normal text-white leading-snug">
                    {project.title}
                  </p>
                  <p class="text-sm text-stone-400 mt-1">{project.location}</p>
                  <div class="mt-4 flex items-center gap-2 text-[11px] font-medium uppercase tracking-[0.15em] text-stone-400 group-hover:text-white transition-colors duration-300">
                    <span>View Project</span>
                    <svg class="w-3.5 h-3.5 transform transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center md:hidden">
        <a
          href="/portfolio"
          class="inline-flex items-center gap-2 text-[12px] font-medium uppercase tracking-[0.15em] text-stone-400 hover:text-white transition-colors duration-300"
        >
          View All Projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-24 lg:py-32 bg-deep-dark">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4 reveal-on-scroll">
        {homeStats.map((stat) => (
          <div class="text-center py-8">
            <span class="font-[Playfair_Display] text-4xl md:text-5xl lg:text-6xl font-normal text-white">{stat.number}</span>
            <p class="mt-3 text-[11px] font-medium uppercase tracking-[0.2em] text-stone-400">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1920&q=80"
        alt="Architecture detail"
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-deep/85"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1400px] px-6 lg:px-12 text-center">
      <div class="max-w-2xl mx-auto reveal-on-scroll">
        <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-accent mb-6">Start Your Project</p>
        <h2 class="font-[Playfair_Display] text-3xl md:text-4xl lg:text-5xl font-normal text-white leading-snug">
          Ready to bring your vision to life?
        </h2>
        <p class="mt-6 text-base leading-relaxed text-stone-400 font-light">
          In a market where timing and compliance are everything, acting now ensures
          you secure today's advantages in cost, value, and entitlement.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-3 mt-10 bg-white text-stone-950 px-10 py-4 text-[12px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:bg-stone-200"
        >
          Free Consultation
