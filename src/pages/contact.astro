---
import Layout from "../layouts/Layout.astro";
import { CONTACT_INFO } from "../data/site";
---

<Layout title="Contact">
  <!--
    Contact form — POSTs to /api/contact (Cloudflare Pages Function → Resend).
    setupFormLogic(prefix) wires: dynamic subcategory dropdown, submission states.
    All element IDs use the ${prefix}-* convention. See AI-GUIDE.md.
  -->

  <p>{CONTACT_INFO.email}</p>
  <p>{CONTACT_INFO.phone}</p>
  <p>{CONTACT_INFO.location}</p>

  <form id="ct-contact-form">
    <div>
      <label for="ct-name">Name *</label>
      <input type="text" id="ct-name" name="name" required autocomplete="name" />
    </div>

    <div>
      <label for="ct-email">Email *</label>
      <input type="email" id="ct-email" name="email" required autocomplete="email" />
    </div>

    <div>
      <label for="ct-phone">Phone</label>
      <input type="tel" id="ct-phone" name="phone" autocomplete="tel" />
    </div>

    <div>
      <label for="ct-address">Address</label>
      <input type="text" id="ct-address" name="address" autocomplete="street-address" />
    </div>

    <div>
      <label for="ct-projectType">Type</label>
      <select id="ct-projectType" name="projectType">
        <option value="">Select type</option>
        <option value="residential">Residential</option>
        <option value="commercial">Commercial</option>
      </select>
    </div>

    <div id="ct-subcategory-wrap" class="opacity-0 max-h-0 overflow-hidden pointer-events-none">
      <label for="ct-subcategory">Scope</label>
      <select id="ct-subcategory" name="subcategory">
        <option value="">Select scope</option>
      </select>
    </div>

    <div>
      <label for="ct-message">Message *</label>
      <textarea id="ct-message" name="message" required rows="5"></textarea>
    </div>

    <div>
      <input type="checkbox" id="ct-constructionEstimate" name="constructionEstimate" value="yes" />
      <label for="ct-constructionEstimate">Request estimate?</label>
    </div>

    <div id="ct-form-error" class="hidden"></div>

    <button type="submit" id="ct-submit-btn">
      <span id="ct-btn-text">Send</span>
      <span id="ct-btn-arrow">&rarr;</span>
      <span id="ct-btn-spinner" class="hidden">...</span>
    </button>
  </form>

  <div id="ct-form-success" class="hidden">
    <p>Message sent.</p>
  </div>
</Layout>

<script>
  import { setupFormLogic } from "../scripts/contact-form";
  setupFormLogic("ct");
</script>
