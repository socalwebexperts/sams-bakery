---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact" description="Get in touch with E.V Design Studio for your complimentary architectural consultation.">
  <!-- Page Header -->
  <section class="pt-36 pb-16 lg:pt-44 lg:pb-20">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="max-w-3xl">
        <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-accent mb-6 animate-fade-in">Get in Touch</p>
        <h1 class="font-[Playfair_Display] text-5xl md:text-6xl lg:text-7xl font-medium leading-[0.95] text-white animate-fade-up">
          Contact<br />
          <span class="italic font-normal text-stone-300">Us</span>
        </h1>
        <p class="mt-6 text-base lg:text-lg leading-relaxed text-stone-400 font-light max-w-xl animate-fade-up" style="animation-delay: 0.2s">
          Connect with us for your complimentary consultation and experience the
          level of service trusted by clients who demand the very best.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="pb-28 lg:pb-40">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20">
        <!-- Contact Info -->
        <div class="lg:col-span-4 space-y-12 reveal-on-scroll">
          <div>
            <h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-4">Office</h3>
            <p class="text-base text-stone-300 leading-relaxed">
              Los Angeles, California<br />
              United States
            </p>
          </div>

          <div>
            <h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-4">Email</h3>
            <a
              href="mailto:info@evdesignstudio.com"
              class="text-base text-stone-300 hover:text-white transition-colors duration-300"
            >
              info@evdesignstudio.com
            </a>
          </div>

          <div>
            <h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-4">Phone</h3>
            <a
              href="tel:+1234567890"
              class="text-base text-stone-300 hover:text-white transition-colors duration-300"
            >
              +1 (234) 567-890
            </a>
          </div>

          <div>
            <h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-4">Follow</h3>
            <div class="flex gap-5">
              <a href="#" class="text-stone-500 hover:text-white transition-colors duration-300" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a href="#" class="text-stone-500 hover:text-white transition-colors duration-300" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>

          <div class="pt-6 border-t border-stone-800/50">
            <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-stone-500 mb-3">Services</p>
            <p class="text-sm text-stone-400 leading-relaxed">
              Architecture &middot; Plans &middot; Permitting &middot; Consulting &middot; Tutorials
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-8 reveal-on-scroll" style="transition-delay: 0.15s">
          <div class="bg-stone-900/30 border border-stone-800/50 p-8 lg:p-12">
            <h2 class="font-[Playfair_Display] text-2xl md:text-3xl font-normal text-white mb-2">
              Start a Conversation
            </h2>
            <p class="text-sm text-stone-500 mb-10">
              Tell us about your project and we'll get back to you within 24 hours.
            </p>

            <form id="contact-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="firstName" class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-3">
                    First Name *
                  </label>
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    required
                    class="w-full bg-transparent border-b border-stone-700 pb-3 text-base text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                    placeholder="John"
                  />
                </div>
                <div>
                  <label for="lastName" class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-3">
                    Last Name *
                  </label>
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    required
                    class="w-full bg-transparent border-b border-stone-700 pb-3 text-base text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                    placeholder="Doe"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-3">
                    Email *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full bg-transparent border-b border-stone-700 pb-3 text-base text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                    placeholder="john@example.com"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-3">
                    Phone
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full bg-transparent border-b border-stone-700 pb-3 text-base text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300"
                    placeholder="+1 (234) 567-890"
                  />
                </div>
              </div>

              <div>
                <label for="projectType" class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-3">
                  Project Type *
                </label>
                <select
                  id="projectType"
                  name="projectType"
                  required
                  class="w-full bg-transparent border-b border-stone-700 pb-3 text-base text-white focus:border-accent focus:outline-none transition-colors duration-300 appearance-none cursor-pointer"
                >
                  <option value="" class="bg-stone-900">Select a project type</option>
                  <option value="residential" class="bg-stone-900">Residential</option>
                  <option value="commercial" class="bg-stone-900">Commercial</option>
                  <option value="permitting" class="bg-stone-900">Permitting Only</option>
                  <option value="consulting" class="bg-stone-900">Consulting</option>
                  <option value="other" class="bg-stone-900">Other</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500 mb-3">
                  Tell Us About Your Project *
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full bg-transparent border-b border-stone-700 pb-3 text-base text-white placeholder-stone-600 focus:border-accent focus:outline-none transition-colors duration-300 resize-none"
                  placeholder="Describe your project, timeline, and any specific requirements..."
                ></textarea>
              </div>

              <div class="pt-4">
                <button
                  type="submit"
                  class="inline-flex items-center gap-3 bg-white text-stone-950 px-10 py-4 text-[12px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 hover:bg-stone-200 w-full md:w-auto justify-center"
                >
                  Send Message
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </button>
              </div>
            </form>

            <div id="form-success" class="hidden py-12 text-center">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full border border-accent/30 mb-6">
                <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" /></svg>
              </div>
              <h3 class="font-[Playfair_Display] text-2xl text-white mb-2">Message Sent</h3>
              <p class="text-stone-400">Thank you for reaching out. We'll be in touch within 24 hours.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const success = document.getElementById("form-success")!;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    form.style.display = "none";
    success.classList.remove("hidden");
  });
</script>
