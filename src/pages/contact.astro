---
import Layout from "../layouts/Layout.astro";
import { CONTACT_INFO } from "../data/site";
---

<Layout title="Contact">

  <!-- ═══ HERO ═══ -->
  <section class="bg-cream py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="font-serif text-4xl lg:text-5xl text-stone-900 mb-4">Get in Touch</h1>
      <p class="text-stone-500 text-lg leading-relaxed">
        Have a question, want to place a special order, or need catering for your next event?
        We would love to hear from you.
      </p>
    </div>
  </section>

  <!-- ═══ CONTACT GRID ═══ -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- INFO SIDEBAR -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="text-xs tracking-[0.2em] uppercase text-primary font-medium mb-3">Visit Us</h2>
            <address class="not-italic text-stone-600 leading-relaxed">
              <p class="mb-2">{CONTACT_INFO.location}</p>
              <p>
                <a href={CONTACT_INFO.phoneHref} class="hover:text-primary transition-colors">{CONTACT_INFO.phone}</a>
              </p>
              <p>
                <a href={`mailto:${CONTACT_INFO.email}`} class="hover:text-primary transition-colors">{CONTACT_INFO.email}</a>
              </p>
            </address>
          </div>

          <div>
            <h2 class="text-xs tracking-[0.2em] uppercase text-primary font-medium mb-3">Hours</h2>
            <ul class="space-y-1.5 text-stone-600">
              <li class="flex justify-between max-w-xs"><span>Monday – Saturday</span><span>7 am – 7 pm</span></li>
              <li class="flex justify-between max-w-xs"><span>Sunday</span><span>8 am – 5 pm</span></li>
            </ul>
          </div>

          <div class="overflow-hidden rounded-sm border border-stone-200 bg-stone-100 ring-1 ring-stone-100">
            <div class="relative aspect-[4/3] w-full min-h-[240px]">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3302.3261086194534!2d-118.25322752280015!3d34.13799807312489!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2c102cd18c0f5%3A0x9f3dc227b982432c!2s400%20Raleigh%20St%2C%20Glendale%2C%20CA%2091205!5e0!3m2!1sen!2sus!4v1776396606664!5m2!1sen!2sus"
                class="absolute inset-0 h-full w-full border-0"
                title="Map: Sam's Armenian Bakery, 400 Raleigh St, Glendale, CA 91205"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              />
            </div>
          </div>
        </div>

        <!-- FORM -->
        <div class="lg:col-span-3">
          <h2 class="font-serif text-2xl text-stone-900 mb-6">Send Us a Message</h2>

          <form id="ct-contact-form" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="ct-name" class="block text-xs tracking-[0.1em] uppercase text-stone-500 font-medium mb-2">Name *</label>
                <input
                  type="text"
                  id="ct-name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full px-4 py-3 border border-stone-200 text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-primary transition-colors"
                />
              </div>
              <div>
                <label for="ct-email" class="block text-xs tracking-[0.1em] uppercase text-stone-500 font-medium mb-2">Email *</label>
                <input
                  type="email"
                  id="ct-email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-3 border border-stone-200 text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-primary transition-colors"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="ct-phone" class="block text-xs tracking-[0.1em] uppercase text-stone-500 font-medium mb-2">Phone</label>
                <input
                  type="tel"
                  id="ct-phone"
                  name="phone"
                  autocomplete="tel"
                  class="w-full px-4 py-3 border border-stone-200 text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-primary transition-colors"
                />
              </div>
              <div>
                <label for="ct-projectType" class="block text-xs tracking-[0.1em] uppercase text-stone-500 font-medium mb-2">Inquiry Type</label>
                <select
                  id="ct-projectType"
                  name="projectType"
                  class="w-full px-4 py-3 border border-stone-200 text-sm text-stone-900 bg-white focus:outline-none focus:border-primary transition-colors"
                >
                  <option value="">Select type</option>
                  <option value="general">General Inquiry</option>
                  <option value="catering">Catering</option>
                  <option value="custom">Custom Order</option>
                  <option value="event">Event</option>
                  <option value="feedback">Feedback</option>
                </select>
              </div>
            </div>

            <div id="ct-subcategory-wrap" class="opacity-0 max-h-0 overflow-hidden pointer-events-none">
              <label for="ct-subcategory" class="block text-xs tracking-[0.1em] uppercase text-stone-500 font-medium mb-2">Details</label>
              <select
                id="ct-subcategory"
                name="subcategory"
                class="w-full px-4 py-3 border border-stone-200 text-sm text-stone-900 bg-white focus:outline-none focus:border-primary transition-colors"
              >
                <option value="">Select details</option>
              </select>
            </div>

            <div>
              <label for="ct-message" class="block text-xs tracking-[0.1em] uppercase text-stone-500 font-medium mb-2">Message *</label>
              <textarea
                id="ct-message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 border border-stone-200 text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-primary transition-colors resize-none"
              ></textarea>
            </div>

            <div id="ct-form-error" class="hidden text-sm text-red-600 bg-red-50 px-4 py-3"></div>

            <button
              type="submit"
              id="ct-submit-btn"
              class="inline-flex items-center justify-center px-8 py-3.5 bg-primary text-white text-sm tracking-[0.12em] uppercase font-medium hover:bg-primary-dark transition-colors w-full sm:w-auto"
            >
              <span id="ct-btn-text">Send Message</span>
              <span id="ct-btn-arrow" class="ml-2">&rarr;</span>
              <span id="ct-btn-spinner" class="hidden ml-2">
                <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </span>
            </button>
          </form>

          <div id="ct-form-success" class="hidden mt-8 text-center py-12 bg-cream">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
              <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <p class="font-serif text-2xl text-stone-900 mb-2">Message Sent</p>
            <p class="text-stone-500">Thank you for reaching out. We will get back to you soon.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  import { setupFormLogic } from "../scripts/contact-form";
  setupFormLogic("ct");
</script>
