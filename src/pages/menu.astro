---
import Layout from "../layouts/Layout.astro";

const categories = [
  {
    name: "Pastries",
    items: [
      { name: "Gata", desc: "Sweet pastry with a buttery walnut and sugar filling, baked to a golden finish" },
      { name: "Nazook", desc: "Flaky rolled pastry layers with a sweet cream and butter center" },
      { name: "Choreg", desc: "Soft braided sweet bread, lightly glazed with mahlab and sesame" },
      { name: "Pakhlava", desc: "Layers of delicate phyllo dough filled with spiced walnuts and honey syrup" },
      { name: "Tahini Rolls", desc: "Spiraled pastry with a rich tahini and sugar filling" },
      { name: "Bourma", desc: "Cylindrical rolled pastry with pistachios and a light syrup glaze" },
    ],
  },
  {
    name: "Breads",
    items: [
      { name: "Lavash", desc: "Traditional Armenian flatbread, thin and soft, perfect for wrapping" },
      { name: "Matnakash", desc: "Oval hearth bread with a tender crumb and slightly crisp crust" },
      { name: "Peda Bread", desc: "Round flatbread topped with sesame seeds and nigella" },
      { name: "Cheese Boat", desc: "Boat-shaped bread filled with a blend of Armenian cheeses" },
    ],
  },
  {
    name: "Savory",
    items: [
      { name: "Lahmajun", desc: "Thin-crust flatbread with seasoned ground meat, herbs, and tomato" },
      { name: "Spinach Pie", desc: "Flaky pastry filled with spinach, onions, and lemon" },
      { name: "Cheese Beoreg", desc: "Layered phyllo pastry filled with feta and herbs" },
      { name: "Meat Beoreg", desc: "Crispy phyllo layers stuffed with seasoned ground beef and onions" },
      { name: "Sou Beoreg", desc: "Boiled dough layers with a rich cheese and egg filling" },
    ],
  },
];
---

<Layout title="Menu">

  <!-- ═══ HERO ═══ -->
  <section class="bg-cream py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="font-serif text-4xl lg:text-5xl text-stone-900 mb-4">Our Menu</h1>
      <p class="text-stone-500 text-lg leading-relaxed">
        Every item is handcrafted daily with traditional Armenian recipes and the finest ingredients.
      </p>
    </div>
  </section>

  <!-- ═══ FEATURED ITEMS GRID ═══ -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-end justify-between mb-10 lg:mb-14">
        <div>
          <p class="text-xs tracking-[0.2em] uppercase text-primary font-medium mb-2">Fresh Daily</p>
          <h2 class="font-serif text-3xl lg:text-4xl text-stone-900">Highlights</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-16 lg:mb-24">
        {[
          { name: "Gata", desc: "Sweet pastry with a buttery walnut filling" },
          { name: "Lahmajun", desc: "Traditional thin-crust flatbread" },
          { name: "Nazook", desc: "Flaky rolled pastry with cream filling" },
          { name: "Cheese Beoreg", desc: "Layered phyllo with feta and herbs" },
        ].map((item) => (
          <div class="group">
            <div class="aspect-square bg-gradient-to-br from-amber-50 to-orange-50 mb-4 overflow-hidden flex items-center justify-center">
              <div class="text-center p-4 transition-transform duration-500 group-hover:scale-105">
                <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-primary/5 flex items-center justify-center">
                  <svg class="w-8 h-8 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                  </svg>
                </div>
                <p class="text-xs text-stone-400 tracking-wider uppercase">Placeholder</p>
              </div>
            </div>
            <h3 class="font-serif text-lg text-stone-900">{item.name}</h3>
            <p class="text-sm text-stone-500 mt-1">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- ═══ FULL MENU LIST ═══ -->
      {categories.map((category) => (
        <div class="mb-16 last:mb-0">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="font-serif text-2xl lg:text-3xl text-stone-900 shrink-0">{category.name}</h2>
            <div class="h-px bg-stone-200 flex-1"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
            {category.items.map((item) => (
              <div class="flex gap-4 group py-3 border-b border-stone-100">
                <div class="w-16 h-16 shrink-0 bg-gradient-to-br from-amber-50 to-orange-50 flex items-center justify-center">
                  <svg class="w-6 h-6 text-primary/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-serif text-lg text-stone-900">{item.name}</h3>
                  <p class="text-sm text-stone-500 mt-0.5 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="bg-primary py-14 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-serif text-2xl lg:text-3xl text-white mb-3">Looking for Something Special?</h2>
      <p class="text-white/70 mb-6">We take custom orders for celebrations, holidays, and events of all sizes.</p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-3.5 bg-white text-primary text-sm tracking-[0.12em] uppercase font-medium hover:bg-cream transition-colors"
      >
        Place a Custom Order
      </a>
    </div>
  </section>

</Layout>
