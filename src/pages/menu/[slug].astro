---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("menu");
  return entries.map((entry) => {
    const slug = entry.id.split("/").pop()!.replace(/\.md$/i, "");
    return { params: { slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, price, category } = entry.data;
---

<Layout title={title}>
  <article class="max-w-2xl mx-auto px-4 py-16 lg:py-20">
    <p class="text-xs tracking-[0.2em] uppercase text-primary font-medium mb-2">{category}</p>
    <h1 class="font-serif text-3xl lg:text-4xl text-stone-900 mb-4">{title}</h1>
    <p class="text-xl font-medium text-stone-900 tabular-nums mb-6">{price}</p>
    {description ? <p class="text-stone-600 leading-relaxed mb-8">{description}</p> : null}
    <div class="max-w-none text-stone-700 leading-relaxed space-y-4 mb-10">
      <Content />
    </div>
    <a href="/menu" class="text-sm tracking-[0.08em] uppercase font-medium text-primary hover:text-primary-dark">
      ← Full menu
    </a>
  </article>
</Layout>
